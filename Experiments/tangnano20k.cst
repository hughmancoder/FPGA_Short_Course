// Physical Constraints for Tang Nano 20K (GW2AR-LV18QN88C8/I7)

// Clock (27MHz crystal)
IO_LOC "i_clk" 4;
IO_PORT "i_clk" PULL_MODE=UP;

// LEDs (Active Low)
IO_LOC "o_led[0]" 15;
IO_LOC "o_led[1]" 16;
IO_LOC "o_led[2]" 17;
IO_LOC "o_led[3]" 18;
IO_LOC "o_led[4]" 19;
IO_LOC "o_led[5]" 20;

// Buttons / Switches (S1 and S2)
IO_LOC "i_sw[0]" 88; // S1
IO_LOC "i_sw[1]" 87; // S2
IO_PORT "i_sw[0]" PULL_MODE=NONE;
IO_PORT "i_sw[1]" PULL_MODE=NONE;
